APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
COMMUNICATIONS_TRANSACTIONAL_PROVIDER=log
COMMUNICATIONS_QUEUE_CONNECTION="${QUEUE_CONNECTION}"
COMMUNICATIONS_QUEUE=communications
COMMUNICATIONS_RETRY_TRIES=3
COMMUNICATIONS_RETRY_BACKOFF_SECONDS=60,300,900
COMMUNICATIONS_PROCESSING_TIMEOUT_SECONDS=300
COMMUNICATIONS_ADMIN_NOTIFICATION_EMAIL=
COMMUNICATIONS_ADMIN_NOTIFICATION_NAME="${APP_NAME}"
COMMUNICATIONS_MARKETING_PROVIDER=null
COMMUNICATIONS_MARKETING_DEFAULT_AUDIENCE_KEY=audience.general
COMMUNICATIONS_POSTMARK_MAILER=postmark
COMMUNICATIONS_LOG_MAILER=log
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_TIMEOUT=10
MAILCHIMP_AUDIENCE_GENERAL_ID=
MAILCHIMP_AUDIENCE_CONSULTATION_ID=
MAILCHIMP_TAG_CONTACT_REQUESTED=contact_requested
MAILCHIMP_TAG_CONSULTATION_REQUESTED=consultation_requested
MAILCHIMP_TAG_LEAD_CREATED=lead_created
MAILCHIMP_TAG_POPUP_SUBMITTED=popup_submitted
MAILCHIMP_TRIGGER_TAG_CONTACT_REQUESTED=automation_contact_requested
MAILCHIMP_TRIGGER_TAG_CONSULTATION_REQUESTED=automation_consultation_requested
MAILCHIMP_TRIGGER_TAG_POPUP_SUBMITTED=automation_popup_submitted

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
